{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "strict": true,
        
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "./src",
        "outDir": "./build",

        "baseUrl": "./src",
        "ignoreDeprecations": "6.0",
        "paths": {
            "#settings/*": ["./settings/*"],
            "#functions/*": ["./functions/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}